{
  "name": "arc-1",
  "version": "0.6.0",
  "description": "ARC-1 — MCP Server for SAP ABAP Systems",
  "author": "Marian Zeis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marianfoo/arc-1"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "arc1": "./bin/arc1.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/aff/schemas && cp -r src/aff/schemas dist/aff/schemas",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --transport http-streamable",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:btp": "vitest run --config vitest.integration.config.ts tests/integration/btp-abap.integration.test.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test:eval": "vitest run --config vitest.eval.config.ts",
    "test:e2e": "vitest run --config tests/e2e/vitest.e2e.config.ts",
    "test:e2e:deploy": "bash scripts/e2e-deploy.sh",
    "test:e2e:stop": "bash scripts/e2e-stop.sh",
    "test:e2e:full": "npm run build && npm run test:e2e:deploy && npm run test:e2e; EXIT=$?; npm run test:e2e:stop; exit $EXIT"
  },
  "dependencies": {
    "@abaplint/core": "^2.115.27",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@sap/xsenv": "^6.1.0",
    "@sap/xssec": "^4.13.0",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.9",
    "jose": "^6.2.2",
    "undici": "^8.0.2",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vitest": "^4.1.1"
  }
}
